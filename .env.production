# Database
DB_PASSWORD=your_secure_database_password_here
# JWT
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_here_at_least_32_chars
JWT_EXPIRATION=86400000

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# MinIO
MINIO_ROOT_USERNAME=minioadmin
MINIO_ROOT_PASSWORD=your_minio_admin_password_here

# CORS - Use * for all origins (works with Nginx proxy), or set specific domain
CORS_ORIGINS=your IP address here, or * for all origins
