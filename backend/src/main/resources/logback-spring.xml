<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 自定义 DB_SQL logger -->
    <logger name="DB_SQL" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Hibernate SQL 日志关闭，使用 DB_SQL logger 输出结构化日志 -->
    <logger name="org.hibernate.SQL" level="OFF" additivity="false"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%logger{36}) - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>