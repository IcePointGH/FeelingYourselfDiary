# 本地开发环境配置
# 复制此文件为 application-local.properties 并填入实际值
# 或在 IDE 中设置环境变量后激活 local profile

server.port=8080
spring.application.name=backend

# Database Configuration
spring.datasource.url=${DB_URL:jdbc:mysql://localhost:3306/emotion_diary?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai}
spring.datasource.username=${DB_USERNAME:root}
spring.datasource.password=${DB_PASSWORD}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA Configuration
spring.jpa.hibernate.ddl-auto=update
spring.jpa.properties.hibernate.format_sql=false
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.session_factory.inject_statement_inspector=true

# JWT Configuration
jwt.secret=${JWT_SECRET}
jwt.expiration=${JWT_EXPIRATION:86400000}

# CORS Configuration (for local development)
cors.allowed-origins=${CORS_ORIGINS:http://localhost:3000}

# Activate local profile
spring.profiles.active=local